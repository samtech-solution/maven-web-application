pipeline
{
    agent any

    tools
    {
        maven 'Maven_3.9.9'
    }

    environment
    {
        buildNumber = "${BUILD_NUMBER}"
    }

    stages
    {
        stage('Checkout Code from GitHub')
        {
            steps()
            {
                git branch: 'DevOpsDecemberBatch', url: 'https://github.com/MithunTechnologiesDevOps/maven-web-application.git'
            }
        }

        stage('Build Maven Artifact')
        {
            steps()
            {
                sh 'mvn clean package'
            }
        }

        stage('Build Docker Image')
        {
            steps()
            {
                sh 'docker build -t mithuntechnologies/maven-microservice:$buildNumber .'
            }
        }

        stage('PUsh Docker Image to Docker Hub Registry')
        {
            steps()
            {
                withCredentials([string(credentialsId: 'Docker_Hub_Password', variable: 'Docker_Hub_Password')])
                {
                    sh 'docker login -u mithuntechnologies -p ${Docker_Hub_Password}'
                }
                sh 'docker push mithuntechnologies/maven-microservice:$buildNumber'
            }
        }

        stage('Remove Docker Image Locally in Jenkins')
        {
            steps()
            {
                sh 'docker rmi -f mithuntechnologies/maven-microservice:$buildNumber'
            }
        }

        stage('Deploy Application to Docker Deployment Server')
        {
            steps()
            {
                sshagent(['DeploymentServer_SSH'])
                {
                    sh "ssh -o StrictHostKeyChecking=no ubuntu@13.233.61.66 docker rm -f maven-container || true"
                    sh "ssh -o StrictHostKeyChecking=no ubuntu@13.233.61.66 docker run -d --name maven-container -p 8080:8080 mithuntechnologies/maven-microservice:${buildNumber}"
                }
            }
        }
    }
}